# OpenAI API (all LLM calls)
OPENAI_API_KEY=sk-...

# Google Perspective API (toxicity scoring)
GOOGLE_PERSPECTIVE_API_KEY=...

# Firebase (session + user data persistence)
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Hume AI voice emotion analysis (optional but recommended for voice tab)
HUME_API_KEY=
HUME_SECRET_KEY=
